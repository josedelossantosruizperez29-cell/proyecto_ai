@{
    ViewData["Title"] = "Login - Emma IA";
}
@model Proyecto_ai.Models.LoginViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Emma IA</title>
    <link rel="stylesheet" href="~/css/account.css">
</head>
<body>
    <div class="screen auth-screen active" id="loginScreen">
  <div class="orb o1"></div><div class="orb o2"></div>
  <div class="acard">
    <div class="a-logo">
      <!-- Improved brain icon -->
    
      <svg class="a-logo-icon pulse" viewBox="0 0 64 64" fill="none">
        <rect width="64" height="64" rx="16" fill="#0c1225"/>
        <rect x=".5" y=".5" width="63" height="63" rx="15.5" stroke="#5b9cf6" stroke-opacity=".28" stroke-width="1"/>
        <g filter="url(#fn1)">
          <path d="M32 15C28 12.5 21 13.5 18 18.5C15.5 22.5 16 27 18.5 30.5C16.5 32 15.5 36 17 39.5C18.5 43.5 22.5 44.5 25.5 43C27 46 29.5 47.5 32 47" stroke="#5b9cf6" stroke-width="2" stroke-linecap="round" fill="none"/>
          <path d="M32 15C36 12.5 43 13.5 46 18.5C48.5 22.5 48 27 45.5 30.5C47.5 32 48.5 36 47 39.5C45.5 43.5 41.5 44.5 38.5 43C37 46 34.5 47.5 32 47" stroke="#5b9cf6" stroke-width="2" stroke-linecap="round" fill="none"/>
          <line x1="32" y1="15" x2="32" y2="47" stroke="#5b9cf6" stroke-width="1.4" stroke-dasharray="3 2.2" stroke-linecap="round"/>
          <path d="M20 27.5Q26 25 32 27.5Q38 25 44 27.5" stroke="#5b9cf6" stroke-width="1.1" opacity=".75" fill="none" stroke-linecap="round"/>
          <path d="M19 34Q26 31.5 32 34Q38 31.5 45 34" stroke="#5b9cf6" stroke-width="1.1" opacity=".75" fill="none" stroke-linecap="round"/>
          <path d="M19.5 40Q26 38 32 40Q38 38 44.5 40" stroke="#5b9cf6" stroke-width="1" opacity=".5" fill="none" stroke-linecap="round"/>
          <!-- Circuit extensions -->
          <line x1="32" y1="13.5" x2="32" y2="8" stroke="#5b9cf6" stroke-width="1" opacity=".45"/>
          <line x1="32" y1="48.5" x2="32" y2="56" stroke="#5b9cf6" stroke-width="1" opacity=".45"/>
          <line x1="16.5" y1="31" x2="10" y2="31" stroke="#5b9cf6" stroke-width="1" opacity=".45"/>
          <line x1="47.5" y1="31" x2="54" y2="31" stroke="#5b9cf6" stroke-width="1" opacity=".45"/>
          <line x1="10" y1="31" x2="10" y2="23" stroke="#5b9cf6" stroke-width=".8" opacity=".3"/>
          <line x1="54" y1="31" x2="54" y2="23" stroke="#5b9cf6" stroke-width=".8" opacity=".3"/>
          <!-- Nodes -->
          <circle cx="32" cy="31" r="3.2" fill="#5b9cf6" opacity=".95">
            <animate attributeName="r" values="3.2;4.8;3.2" dur="2s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values=".95;.35;.95" dur="2s" repeatCount="indefinite"/>
          </circle>
          <circle cx="32" cy="8" r="2.2" fill="#5b9cf6" opacity=".5"/>
          <circle cx="32" cy="56" r="2.2" fill="#5b9cf6" opacity=".5"/>
          <circle cx="10" cy="31" r="2.2" fill="#5b9cf6" opacity=".5"/>
          <circle cx="54" cy="31" r="2.2" fill="#5b9cf6" opacity=".5"/>
          <circle cx="10" cy="23" r="1.6" fill="#5b9cf6" opacity=".3"/>
          <circle cx="54" cy="23" r="1.6" fill="#5b9cf6" opacity=".3"/>
          <circle cx="20" cy="27.5" r="1.7" fill="#5b9cf6" opacity=".5"/>
          <circle cx="44" cy="27.5" r="1.7" fill="#5b9cf6" opacity=".5"/>
          <circle cx="19" cy="34" r="1.7" fill="#5b9cf6" opacity=".5"/>
          <circle cx="45" cy="34" r="1.7" fill="#5b9cf6" opacity=".5"/>
        </g>
        <defs><filter id="fn1" x="-25%" y="-25%" width="150%" height="150%"><feGaussianBlur stdDeviation="1.6" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
      </svg>
      <div class="a-logo-name">Neural<span>Chat</span></div>
    </div>

    <div class="a-title">Bienvenido de vuelta</div>
    <div class="a-sub">Inicia sesión para continuar con tus 3 modelos de IA gratuitos</div>

    <button class="soc-btn">
      <svg width="17" height="17" viewBox="0 0 18 18"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/><path d="M3.964 10.706A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.038l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/></svg>
      Continuar con Google
    </button>
    <button class="soc-btn">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="var(--text2)"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      Continuar con GitHub
    </button>

    <div class="a-div"><span>o con tu correo</span></div>
    <form asp-controller="Account" asp-action="Login" method="post">
    <div class="field"><label>Correo electrónico</label><input name="Correo" type="email" placeholder="tu@email.com"/></div>
    <div class="field">
      <label>Contraseña</label>
      <div class="pw-wrap"><input name="Password" type="password" placeholder="••••••••" id="lp"/><button class="pw-eye" onclick="tpw('lp',this)">👁</button></div>
    </div>
    <button class="a-btn" type="submit">Iniciar sesión →</button>
    <div class="a-link">¿No tienes cuenta? <a href="../Register/Register">Regístrate gratis</a></div>
    <div class="a-link" style="margin-top:8px"><a style="font-size:12px;color:var(--text3)">¿Olvidaste tu contraseña?</a></div>
    </form>
  </div>
</div>
</body>
</html>